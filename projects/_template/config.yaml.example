project:
  name: "{{PROJECT}}"
  owner: "{{OWNER}}"
  description: ""

target:
  base_url: ""
  urls: []

request:
  rate_limit: 1.0
  timeout: 15
  proxy: false
  max_retries: 3

storage:
  type: "jsonl"
  output_dir: "./data/{{OWNER}}/{{PROJECT}}"

schedule:
  cron: ""
  timezone: "Asia/Shanghai"

notify:
  on_success: false
  on_failure: true
  channel: "dingtalk"

compliance:
  robots_txt_checked: false
  rate_limit: 1.0
  data_usage: "internal"
  personal_data: false
  notes: ""
